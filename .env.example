# Local environment variables used by the VoiceForge Express server.
# Copy this file to .env and fill in the values before running `npm run dev`.

# ------------------------------------------------------------------
# ElevenLabs API key (required for real TTS and voice cloning).
# Get a free key at https://elevenlabs.io/
# Leave blank if you are using MOCK_ELEVENLABS=true (see below).
# ------------------------------------------------------------------
ELEVENLABS_API_KEY=paste_your_api_key_here

PORT=3001
CLIENT_URL=http://localhost:5173

# ------------------------------------------------------------------
# MOCK_ELEVENLABS — offline dev/CI mode (no API key or credits needed)
# ------------------------------------------------------------------
# Set to "true" to skip all real ElevenLabs network calls:
#   - POST /api/voice/clone  → returns a fixture voice_id instantly
#   - GET  /api/voice/speak/stream/:id → streams a short silent MP3
#
# This lets you exercise the complete UI flow locally:
#   record → clone → type text → Speak → download audio
# without a paid ElevenLabs plan or any internet access to ElevenLabs.
#
# Safety: has NO effect when NODE_ENV=production (ignored automatically).
# ------------------------------------------------------------------
# MOCK_ELEVENLABS=true
